@model CarimboCreateViewModel

<form asp-controller="Carimbo"
      asp-action="Gerar"
      method="post">

    <select asp-for="TipoAtoId"
            asp-items="@(new SelectList(Model.TiposAto, "Id", "Nome"))">
    </select>

    <select asp-for="FonteId"
            asp-items="@(new SelectList(Model.Fontes, "Id", "Nome"))">
    </select>

    <input asp-for="Bloco" placeholder="Bloco" />

    <input asp-for="Numero" placeholder="Número" />
    <input asp-for="Nome" placeholder="Nome" />

    <select asp-for="BancoId"
            asp-items="@(new SelectList(Model.Bancos, "Id", "Nome"))">
    </select>

    <input asp-for="Agencia" placeholder="Agência" />
    <input asp-for="Conta" placeholder="Conta" />

    <button type="submit">Gerar Carimbo</button>

    <label>
        <input asp-for="EhEmenda" type="checkbox" id="chkEmenda" />
        Emenda
    </label>

    <div id="camposEmenda" style="display:none; margin-top:10px;">

        <input asp-for="NumeroProposta" placeholder="Nº Proposta" />
        <input asp-for="NumeroEmenda" placeholder="Nº Emenda" />
        <input asp-for="NomeParlamentar" placeholder="Nome do Parlamentar" />
        <input asp-for="Partido" placeholder="Partido" />
        <input asp-for="TipoEmenda" placeholder="Tipo da Emenda" />

    </div>


</form>
